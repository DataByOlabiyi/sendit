{
  "framework": "nextjs",
  "buildCommand": "cd ../.. && pnpm turbo build --filter=@sendit/admin",
  "installCommand": "pnpm install",
  "outputDirectory": ".next",
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": "@sendit-supabase-url",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@sendit-supabase-anon-key",
    "SUPABASE_SERVICE_ROLE_KEY": "@sendit-service-role-key",
    "NEXT_PUBLIC_APP_URL": "@sendit-admin-url"
  }
}
